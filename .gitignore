# Runtime state, logs, and generated local data.
data/*
!data/.gitkeep
!data/runtime_example.json

# Session event logs, indexes, and generated long-term memory.
memory/non_productivity/
memory/productivity/
memory/sessions.sqlite3*
data/session_artifacts/

# Temporary test backups created during local validation.
.codex-test-backup-*/
.codex-test-tmp-*/
