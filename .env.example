# Required for model calls.
OPENAI_API_KEY=

# Optional. Leave blank unless a future tool uses web search.
TAVILY_API_KEY=

# Optional. Defaults to gpt-5.4-mini when blank or omitted.
AI4CASTING_MODEL=gpt-5.4-mini

# Optional shell tool settings. Blank paths mean the app uses defaults:
# SHELL_SANDBOX_ROOT -> project root
# SHELL_AUDIT_LOG_PATH -> data/shell_audit.log
SHELL_SANDBOX_ROOT=
SHELL_AUDIT_LOG_PATH=

# Keep these true unless you are intentionally debugging locally.
SHELL_REQUIRE_ALLOWLIST=true
SHELL_ENFORCE_SANDBOX=true

# Keep false for the simple CLI loop. Set true only after adding Deep Agents
# interrupt/resume handling around shell approvals.
SHELL_REQUIRE_APPROVAL=false

# Script execution limits.
SHELL_TIMEOUT_SECONDS=180
SHELL_MAX_OUTPUT_CHARS=12000

# Only allow the executables that skills actually need.
SHELL_ALLOWED_COMMANDS=python,python.exe,py,py.exe,powershell,powershell.exe

# Comma-separated blocked command patterns.
SHELL_DENIED_PATTERNS=&&,||,;,|,>,<,`,$(,../,..\, rm , rmdir , del , erase , format , shutdown , restart-computer , powershell -enc, certutil -decode
